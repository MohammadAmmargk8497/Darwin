# Darwin — environment variables
#
# Copy this file to `.env` and fill in the values you need. `.env` is
# gitignored so secrets never land in git. Any setting also present in
# config/agent_config.json can be overridden here (env vars win).

# --- LLM provider ----------------------------------------------------------
# Override the JSON config's provider/model/api_base from env if desired.
# PROVIDER=ollama
# MODEL_NAME=llama3.2:3b
# API_BASE=http://localhost:11434

# Required when PROVIDER=openai (or any OpenAI-compatible endpoint like Groq,
# OpenRouter, Together). Also read directly by the OpenAI SDK.
OPENAI_API_KEY=

# --- Obsidian --------------------------------------------------------------
# Path to the Obsidian vault where notes are written. If unset, Darwin will
# try <repo>/Darwin Research, ~/Obsidian/Darwin Research, and a couple of
# other common locations.
# OBSIDIAN_VAULT_PATH=/Users/me/Obsidian/Darwin Research

# Only needed if you're using the Local REST API community plugin. The MCP
# server doesn't require it for direct filesystem writes.
OBSIDIAN_API_KEY=

# Port of the Local REST API plugin, if used.
# OBSIDIAN_PORT=27123

# Default folder (vault-relative) where new notes are written.
# DEFAULT_FOLDER=Research/Incoming

# --- arXiv -----------------------------------------------------------------
# Minimum seconds between outbound requests (arXiv asks for ≥3s). Applies
# on top of the arxiv library's own internal rate limiting.
# ARXIV_RATE_LIMIT_SECONDS=3.0

# Retries on transient failures (network errors, UnexpectedEmptyPageError).
# ARXIV_MAX_RETRIES=3

# --- Storage ---------------------------------------------------------------
# Absolute paths override the defaults derived from project root.
# PAPER_STORAGE=/absolute/path/to/papers
# RESEARCH_LOG_DB=/absolute/path/to/research_log.db
# DARWIN_LOG_DIR=/absolute/path/to/logs

# --- Logging ---------------------------------------------------------------
# DARWIN_LOG_LEVEL=INFO
